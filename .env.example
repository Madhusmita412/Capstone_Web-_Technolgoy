# FixIt Smart Complaint Management System - Environment Variables Example

# Copy this file to .env and update values
# Do NOT commit .env file to version control

# ====================
# Environment
# ====================
APP_ENV=production
APP_DEBUG=false
APP_NAME="FixIt - Smart Complaint Management System"

# ====================
# Database Configuration
# ====================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=your_mysql_password
DB_NAME=complaint_system
DB_CHARSET=utf8mb4

# ====================
# Application URLs
# ====================
APP_URL=http://localhost/complaint_web
APP_DOMAIN=localhost

# ====================
# Session Configuration
# ====================
SESSION_TIMEOUT=3600
REMEMBER_ME_DURATION=2592000
SESSION_SECURE=false
SESSION_HTTPONLY=true

# ====================
# Security
# ====================
SECRET_KEY=your_secret_key_here_generate_with_random_string
BCRYPT_ROUNDS=10

# ====================
# Email Configuration (Optional)
# ====================
MAIL_DRIVER=sendmail
MAIL_HOST=localhost
MAIL_PORT=25
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@fixit.local
MAIL_FROM_NAME="FixIt System"

# ====================
# File Upload
# ====================
UPLOAD_DIR=uploads/
MAX_UPLOAD_SIZE=52428800
ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf,doc,docx

# ====================
# Admin Configuration
# ====================
ADMIN_EMAIL=admin@fixit.local
ADMIN_NAME=Administrator

# ====================
# Logging
# ====================
LOG_CHANNEL=single
LOG_LEVEL=error
LOG_PATH=logs/

# ====================
# Cache (Optional)
# ====================
CACHE_DRIVER=file
CACHE_LIFETIME=3600

# ====================
# API Configuration (Optional)
# ====================
API_ENABLED=false
API_RATE_LIMIT=100
API_TIMEOUT=300

# ====================
# Features
# ====================
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_FILE_UPLOADS=true
ENABLE_CAPTCHA=false
ENABLE_TWO_FACTOR_AUTH=false

# ====================
# Third-party Services (Optional)
# ====================
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=

# ====================
# Development
# ====================
SHOW_ERROR_DETAILS=false
ENABLE_DEBUG_BAR=false
ENABLE_PROFILER=false
