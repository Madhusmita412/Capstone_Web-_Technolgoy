{
  "version": 2,
  "functions": {
    "*.php": {
      "runtime": "vercel-php@0.7.4"
    },
    "api/*.php": {
      "runtime": "vercel-php@0.7.4"
    },
    "admin/*.php": {
      "runtime": "vercel-php@0.7.4"
    }
  },
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(.*)\\.php",
      "dest": "/$1.php"
    },
    {
      "src": "/admin/(.*)",
      "dest": "/admin/$1.php"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1.php"
    },
    {
      "src": "/",
      "dest": "/index.php"
    },
    {
      "handle": "filesystem"
    }
  ]
}