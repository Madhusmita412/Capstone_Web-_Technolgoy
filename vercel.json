{
  "version": 2,
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.7.4"
    }
  },
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "^/$",
      "dest": "/api/home.php"
    },
    {
      "src": "^/index\\.php$",
      "dest": "/api/home.php"
    },
    {
      "src": "^/contact\\.php$",
      "dest": "/api/page-contact.php"
    },
    {
      "src": "^/admin/(.+)\\.php$",
      "dest": "/api/admin/$1.php"
    },
    {
      "src": "^/admin/(.+)$",
      "dest": "/api/admin/$1.php"
    },
    {
      "src": "^/api/(.+)$",
      "dest": "/api/$1.php"
    },
    {
      "src": "^/(.+)\\.php$",
      "dest": "/api/$1.php"
    },
    {
      "src": "^/([a-z-]+)$",
      "dest": "/api/$1.php"
    }
  ]
}